{
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                },
                {
                    "key": "Permissions-Policy",
                    "value": "camera=(), microphone=(), geolocation=(self)"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/products/:id",
            "has": [
                {
                    "type": "header",
                    "key": "user-agent",
                    "value": ".*(WhatsApp|Facebook|Twitter|facebookexternalhit|Twitterbot|TelegramBot|Slackbot|discordbot|Googlebot|bingbot|LinkedInBot|Pinterest|bot|crawl|spider).*"
                }
            ],
            "destination": "/api/seo?type=product&id=:id"
        },
        {
            "source": "/categories/:id",
            "has": [
                {
                    "type": "header",
                    "key": "user-agent",
                    "value": ".*(WhatsApp|Facebook|Twitter|facebookexternalhit|Twitterbot|TelegramBot|Slackbot|discordbot|Googlebot|bingbot|LinkedInBot|Pinterest|bot|crawl|spider).*"
                }
            ],
            "destination": "/api/seo?type=category&id=:id"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
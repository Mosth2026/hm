{
    "rewrites": [
        {
            "source": "/products/:id",
            "has": [
                {
                    "type": "header",
                    "key": "user-agent",
                    "value": ".*(WhatsApp|Facebook|Twitter|facebookexternalhit|Twitterbot|TelegramBot|Slackbot|discordbot|Googlebot|bingbot|LinkedInBot|Pinterest|bot|crawl|spider).*"
                }
            ],
            "destination": "/api/seo?type=product&id=:id"
        },
        {
            "source": "/categories/:id",
            "has": [
                {
                    "type": "header",
                    "key": "user-agent",
                    "value": ".*(WhatsApp|Facebook|Twitter|facebookexternalhit|Twitterbot|TelegramBot|Slackbot|discordbot|Googlebot|bingbot|LinkedInBot|Pinterest|bot|crawl|spider).*"
                }
            ],
            "destination": "/api/seo?type=category&id=:id"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}